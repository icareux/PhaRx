<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<HBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.pharmasystem.ui.InventoryController"
      styleClass="root"
      stylesheets="@pharx.css"
      prefWidth="1200" prefHeight="700">

    <!-- ── Sidebar ─────────────────────────────────────────── -->
    <VBox styleClass="sidebar">
        <HBox styleClass="sidebar-logo-row" alignment="CENTER_LEFT" spacing="10">
            <!-- Tab icon placeholder – swap Label for ImageView when ready -->
            <StackPane styleClass="sidebar-logo-box">
                <Label text="Rx" styleClass="sidebar-logo-symbol"/>
            </StackPane>
            <Label text="PhaRx" styleClass="sidebar-brand"/>
        </HBox>
        <Label text="NAVIGATION" styleClass="sidebar-section-label"/>
        <Button text="  ← Dashboard"      styleClass="nav-btn"        onAction="#goBack"          maxWidth="Infinity"/>
        <Button text="  📦  Inventory"     styleClass="nav-btn-active"                             maxWidth="Infinity"/>
        <Region VBox.vgrow="ALWAYS"/>
    </VBox>

    <!-- ── Main content ───────────────────────────────────── -->
    <VBox HBox.hgrow="ALWAYS" styleClass="page-content" spacing="20">

        <!-- Header + action buttons -->
        <HBox alignment="CENTER_LEFT" spacing="10">
            <VBox spacing="4" HBox.hgrow="ALWAYS">
                <Label text="Inventory" styleClass="page-title"/>
                <Label text="Manage medicines, stock and pricing" styleClass="page-subtitle"/>
            </VBox>
            <Button fx:id="removeExpiredBtn"  text="🗑 Remove Expired"  styleClass="btn-danger"     onAction="#handleRemoveExpired"/>
            <Button fx:id="deleteMedicineBtn" text="✕  Delete Medicine" styleClass="btn-danger"     onAction="#handleDeleteMedicine"/>
            <Button fx:id="adjustPriceBtn"    text="Adjust Prices"      styleClass="btn-secondary"  onAction="#openAdjustPrices"/>
            <Button                           text="View Batches"        styleClass="btn-secondary"  onAction="#openViewBatches"/>
            <Button fx:id="updateBtn"         text="Manage Stock"        styleClass="btn-secondary"  onAction="#handleAddButton"/>
            <Button fx:id="addMedicineBtn"    text="+ Add Medicine"      styleClass="btn-primary"    onAction="#openAddMedicine"/>
        </HBox>

        <!-- Search bar -->
        <TextField fx:id="inventorySearch"
                   promptText="Search medicines..."
                   styleClass="search-field"
                   maxWidth="400"
                   onKeyReleased="#onInventorySearch"/>

        <!-- Table card — fills all remaining vertical space -->
        <VBox styleClass="card" VBox.vgrow="ALWAYS" spacing="0">
            <TableView fx:id="table" VBox.vgrow="ALWAYS"
                       styleClass="table-view"
                       style="-fx-background-color: transparent;">
                <columns>
                    <TableColumn fx:id="nameCol"   text="MEDICINE NAME"   prefWidth="240" minWidth="160"/>
                    <TableColumn fx:id="stockCol"  text="STOCK"           prefWidth="90"  minWidth="70"/>
                    <TableColumn fx:id="priceCol"  text="PRICE (₱)"       prefWidth="110" minWidth="80"/>
                    <TableColumn fx:id="expiryCol" text="EXPIRY DATE"     prefWidth="130" minWidth="110"/>
                    <TableColumn fx:id="rxCol"     text="PRESCRIPTION"    prefWidth="120" minWidth="100"/>
                </columns>
                <placeholder>
                    <Label text="No medicines found." styleClass="label-muted"/>
                </placeholder>
            </TableView>
        </VBox>

    </VBox>

</HBox>
